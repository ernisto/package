{
  "name": "package",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Packages": { "$path": "Packages",
        "package": { "$path": "src",
          "Assets": { "$path": "assets" }
        }
      }
    },
    "ServerScriptService": {
      "Packages": { "$path": "ServerPackages" }
    },
    "ServerStorage": {
      "Stories": { "$path": "stories" }
    },
    "TestService": {
      "Packages": { "$path": "DevPackages" },
      "Tests": { "$path": "tests" }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      }
    },
    "HttpService": {
      "$properties": {
        "HttpEnabled": false
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}